# Cloudflare Pages 部署环境变量示例
# 复制此文件为 .env 并填写实际值

# ==================== 必填配置 ====================

# 管理员账号（至少6位）
USERNAME=admin

# 管理员密码（至少6位）
PASSWORD=your_secure_password

# 存储类型：cloudflare-kv（Cloudflare推荐）或 upstash
NEXT_PUBLIC_STORAGE_TYPE=cloudflare-kv

# Upstash Redis 连接信息（仅当使用 upstash 时需要）
# UPSTASH_URL=https://your-instance.upstash.io
# UPSTASH_TOKEN=your_upstash_token

# ==================== 站点配置 ====================

# 站点名称
NEXT_PUBLIC_SITE_NAME=LunaTV

# 站点公告
ANNOUNCEMENT=本网站仅提供影视信息搜索服务，所有内容均来自第三方网站。

# 站点基础URL（Cloudflare Pages 会自动设置）
SITE_BASE=https://your-project.pages.dev

# ==================== 功能配置 ====================

# 搜索最大页数
NEXT_PUBLIC_SEARCH_MAX_PAGE=5

# 是否允许用户注册（设为true开放注册，false关闭）
NEXT_PUBLIC_ALLOW_REGISTRATION=true

# 是否允许修改密码
NEXT_PUBLIC_ALLOW_CHANGE_PASSWORD=true

# ==================== 豆瓣代理配置 ====================

# 豆瓣数据代理类型（推荐使用 cmliussss-cdn-tencent）
NEXT_PUBLIC_DOUBAN_PROXY_TYPE=cmliussss-cdn-tencent
NEXT_PUBLIC_DOUBAN_IMAGE_PROXY_TYPE=cmliussss-cdn-tencent

# ==================== 高级配置 ====================

# 是否禁用色情内容过滤
NEXT_PUBLIC_DISABLE_YELLOW_FILTER=false

# 是否启用流式搜索
NEXT_PUBLIC_FLUID_SEARCH=true
